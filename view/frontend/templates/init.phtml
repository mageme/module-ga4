<?php
/**
 * @var \MageMe\GA4\Block\Init $block
 * @var \Magento\Framework\View\Helper\SecureHtmlRenderer $secureRenderer
 */
$measurementId = $block->escapeJs($block->getMeasurementId());
$currency = $block->escapeJs($block->getCurrencyCode());
$disabledEvents = $block->getDisabledEventsJson();
$sendPageView = $block->isSendPageView() ? 'true' : 'false';
$trackingMode = $block->getTrackingMode();
$isZaraz = ($trackingMode === 'zaraz');
$loadGtag = $block->isLoadGtagEnabled() && !$isZaraz;

$scriptString = <<<SCRIPT
window.mgmGa4Currency = '{$currency}';
window.mgmGa4DisabledEvents = {$disabledEvents};
window.mgmGa4TrackingMode = '{$trackingMode}';
SCRIPT;

if (!$isZaraz) {
    $scriptString .= <<<SCRIPT

window.dataLayer = window.dataLayer || [];
function gtag(){dataLayer.push(arguments);}
SCRIPT;

    if ($loadGtag) {
        $scriptString .= <<<SCRIPT

gtag('js', new Date());
gtag('config', '{$measurementId}', {send_page_view: {$sendPageView}, allow_google_signals: false});

{
    let loaded = false;
    const loadGtag = () => {
        if (loaded) return;
        loaded = true;
        const s = document.createElement('script');
        s.src = 'https://www.googletagmanager.com/gtag/js?id={$measurementId}';
        s.async = true;
        document.head.appendChild(s);
    };
    ['scroll', 'click', 'touchstart', 'mousemove', 'keydown'].forEach(
        (e) => document.addEventListener(e, loadGtag, {once: true, passive: true})
    );
    setTimeout(loadGtag, 3500);
}
SCRIPT;
    }
}
?>
<?= /* @noEscape */ $secureRenderer->renderTag('script', [], $scriptString, false) ?>
