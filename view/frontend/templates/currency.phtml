<?php
/**
 * @var \MageMe\GA4\Block\Currency $block
 * @var \Magento\Framework\View\Helper\SecureHtmlRenderer $secureRenderer
 */
$measurementId = $block->escapeJs($block->getMeasurementId());
$currency = $block->escapeJs($block->getCurrencyCode());

$scriptString = <<<SCRIPT
window.mgmGa4Currency = '{$currency}';
window.dataLayer = window.dataLayer || [];
function gtag(){dataLayer.push(arguments);}
gtag('js', new Date());
gtag('config', '{$measurementId}', {send_page_view: false, allow_google_signals: false});

{
    let loaded = false;
    const loadGtag = () => {
        if (loaded) return;
        loaded = true;
        const s = document.createElement('script');
        s.src = 'https://www.googletagmanager.com/gtag/js?id={$measurementId}';
        s.async = true;
        document.head.appendChild(s);
    };
    ['scroll', 'click', 'touchstart', 'mousemove', 'keydown'].forEach(
        (e) => document.addEventListener(e, loadGtag, {once: true, passive: true})
    );
    setTimeout(loadGtag, 3500);
}
SCRIPT;
?>
<?= /* @noEscape */ $secureRenderer->renderTag('script', [], $scriptString, false) ?>
