<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="breeze.js">
            <arguments>
                <argument name="bundles" xsi:type="array">
                    <item name="ga4" xsi:type="array">
                        <item name="active" xsi:type="boolean">true</item>
                        <item name="sort_order" xsi:type="number">300</item>
                        <item name="items" xsi:type="array">
                            <item name="MageMe_GA4/js/tracker" xsi:type="array">
                                <item name="path" xsi:type="string">MageMe_GA4/js/breeze/tracker</item>
                                <item name="load" xsi:type="array">
                                    <item name="onRequire" xsi:type="boolean">true</item>
                                </item>
                            </item>
                        </item>
                    </item>
                </argument>
            </arguments>
        </referenceBlock>
    </body>
</page>
