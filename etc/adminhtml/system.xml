<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <section id="mageme_ga4" translate="label" type="text" sortOrder="200"
                 showInDefault="1" showInWebsite="1" showInStore="1">
            <label>Google Analytics 4</label>
            <tab>mageme</tab>
            <resource>MageMe_GA4::config</resource>
            <group id="general" translate="label" type="text" sortOrder="10"
                   showInDefault="1" showInWebsite="1" showInStore="1">
                <label>General Settings</label>
                <field id="active" translate="label comment" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Enable GA4 ecommerce tracking via Cloudflare Zaraz.</comment>
                </field>
                <field id="measurement_id" translate="label comment" type="text" sortOrder="20"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Measurement ID</label>
                    <comment>GA4 Measurement ID (G-XXXXXXXXXX). Used for server-side Measurement Protocol.</comment>
                </field>
                <field id="api_secret" translate="label comment" type="obscure" sortOrder="30"
                       showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>API Secret</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <comment>GA4 Measurement Protocol API secret. Create in GA4 Admin > Data Streams > Measurement Protocol API secrets.</comment>
                </field>
                <field id="server_side_purchase" translate="label comment" type="select" sortOrder="40"
                       showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Server-side Purchase Tracking</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Send purchase events via Measurement Protocol as a fallback. Requires API Secret.</comment>
                </field>
                <field id="debug" translate="label comment" type="select" sortOrder="50"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Debug Mode</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Log Measurement Protocol requests to var/log/mageme_ga4.log and use GA4 debug endpoint.</comment>
                </field>
            </group>
        </section>
    </system>
</config>
